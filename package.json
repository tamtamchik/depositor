{
  "name": "depositor",
  "version": "1.0.0",
  "description": "CLI tool for generating Ethereum validator deposit_data and keystore files on testnets",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "depositor": "dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamtamchik/depositor.git"
  },
  "homepage": "https://github.com/tamtamchik/depositor#readme",
  "bugs": {
    "url": "https://github.com/tamtamchik/depositor/issues"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "generate": "node --experimental-strip-types src/index.ts",
    "build": "tsdown src/index.ts src/bin.ts --format esm --dts --platform node",
    "test": "node --experimental-strip-types --test test/**/*.ts",
    "test:coverage": "node --experimental-strip-types --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info test/**/*.ts",
    "lint": "biome check . && tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "ethereum",
    "eth2",
    "deposit",
    "keystore",
    "bls",
    "validator"
  ],
  "author": "Yuri Tkachenko <yuri.tam.tkachenko@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^24.13.2",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "tar": "7.5.16",
    "uuid": "11.1.1"
  },
  "dependencies": {
    "@chainsafe/bls-keygen": "^0.4.0",
    "@chainsafe/bls-keystore": "^3.1.0",
    "@chainsafe/ssz": "^1.6.0",
    "@noble/curves": "^2.2.0",
    "@scure/bip39": "^2.2.0"
  }
}
