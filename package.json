{
  "name": "depositor",
  "version": "1.0.0",
  "description": "CLI tool for generating Ethereum 2.0 deposit_data and keystore files (Node 23 + tsx)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "generate": "tsx src/index.ts",
    "build": "tsc --project tsconfig.json",
    "test": "node --import tsx/esm --test test/**/*.ts",
    "test:coverage": "node --import tsx/esm --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info test/**/*.ts",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "ethereum",
    "eth2",
    "deposit",
    "keystore",
    "bls",
    "validator"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=23"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "tar": "7.5.16",
    "uuid": "11.1.1"
  },
  "dependencies": {
    "@chainsafe/bls": "^8.2.0",
    "@chainsafe/bls-keygen": "^0.4.0",
    "@chainsafe/bls-keystore": "^3.1.0",
    "@chainsafe/ssz": "^1.6.0",
    "@lodestar/params": "^1.43.0",
    "@lodestar/state-transition": "^1.43.0",
    "@lodestar/types": "^1.43.0",
    "@scure/bip39": "^1.6.0"
  }
}
